{
  "meta": {
    "name": "adampang.com design system",
    "version": "2.0.0",
    "description": "Clean card-based minimal. Light-first, near-white surfaces, one blue primary, five accent hues that each own a section.",
    "source": "src/design/tokens.json",
    "note": "Single source of truth. tailwind.config.ts, /design, /design/tokens.json and /design/tokens.css are all generated from this file. Never hardcode a hex anywhere else."
  },

  "color": {
    "surface": {
      "bg":      { "light": "#fafafa", "dark": "#0a0a0a", "role": "page background base" },
      "bg-mid":  { "light": "#f0f4ff", "dark": "#0d0d14", "role": "page gradient midpoint" },
      "bg-end":  { "light": "#e8ecf8", "dark": "#0a0f1a", "role": "page gradient end" },
      "card":    { "light": "#ffffff", "dark": "#141414", "role": "raised card surface" },
      "line":    { "light": "#e2e8f0", "dark": "#27272a", "role": "hairlines, card borders" }
    },
    "content": {
      "fg":      { "light": "#1a1a1a", "dark": "#fafafa", "role": "primary text" },
      "muted":   { "light": "#5b6674", "dark": "#a1a1aa", "role": "secondary text, captions" },
      "faint":   { "light": "#626b78", "dark": "#8b8b93", "role": "tertiary text, metadata" }
    },
    "brand": {
      "accent":     { "light": "#2563eb", "dark": "#60a5fa", "role": "links, CTAs, focus ring" },
      "accent-ink": { "light": "#1d4ed8", "dark": "#93c5fd", "role": "accent text on light surfaces (AA-safe)" },
      "on-accent":  { "light": "#ffffff", "dark": "#0a0a0a", "role": "label sitting on an accent fill" }
    },
    "section": {
      "sights":     { "light": "#f59e0b", "dark": "#fbbf24", "role": "sights section accent. Fills and dots only, never text on light." },
      "sounds":     { "light": "#38bdf8", "dark": "#7dd3fc", "role": "sounds section accent. Fills and dots only, never text on light." },
      "curiosity":  { "light": "#34d399", "dark": "#6ee7b7", "role": "curiosity section accent, live status. Fills and dots only." },
      "creativity": { "light": "#c084fc", "dark": "#d8b4fe", "role": "creativity section accent. Fills and dots only." },
      "alert":      { "light": "#ef4444", "dark": "#f87171", "role": "destructive fill" },
      "alert-ink":  { "light": "#c81e1e", "dark": "#fca5a5", "role": "destructive TEXT (AA-safe on card)" }
    }
  },

  "type": {
    "family": {
      "display": { "value": "var(--font-display), system-ui, sans-serif", "role": "Space Grotesk 700. Headings." },
      "body":    { "value": "var(--font-body), system-ui, sans-serif",    "role": "Lato 300/400/700. Prose." },
      "mono":    { "value": "var(--font-mono), ui-monospace, monospace",  "role": "JetBrains Mono. Numerals, labels." }
    },
    "scale": {
      "caption": { "size": "0.75rem",  "leading": "1.4",  "role": "12px. Metadata, footnotes." },
      "label":   { "size": "0.8125rem","leading": "1.4",  "role": "13px. Eyebrows, nav." },
      "body":    { "size": "1rem",     "leading": "1.65", "role": "16px. Default prose." },
      "lead":    { "size": "1.125rem", "leading": "1.6",  "role": "18px. Intro paragraphs." },
      "h3":      { "size": "1.5rem",   "leading": "1.2",  "role": "24px. Card titles." },
      "h2":      { "size": "1.875rem", "leading": "1.15", "role": "30px. Section titles." },
      "h1":      { "size": "2.25rem",  "leading": "0.95", "role": "36px. Page title. 3rem at sm+." }
    },
    "tracking": {
      "tightest": { "value": "-0.02em", "role": "display headings" },
      "tighter":  { "value": "-0.01em", "role": "subheads" },
      "label":    { "value": "0.12em",  "role": "uppercase eyebrows" },
      "wide":     { "value": "0.22em",  "role": "uppercase kickers" }
    }
  },

  "space": {
    "1": { "value": "0.25rem", "role": "4px. Icon gap." },
    "2": { "value": "0.5rem",  "role": "8px. Inline gap." },
    "3": { "value": "0.75rem", "role": "12px. Tight stack." },
    "4": { "value": "1rem",    "role": "16px. Default stack." },
    "5": { "value": "1.25rem", "role": "20px. Card padding, mobile gutter." },
    "6": { "value": "1.5rem",  "role": "24px. Card padding at sm+." },
    "8": { "value": "2rem",    "role": "32px. Between subsections." },
    "10":{ "value": "2.5rem",  "role": "40px. Between sections." },
    "14":{ "value": "3.5rem",  "role": "56px. Page top/bottom at sm+." }
  },

  "radius": {
    "sm":   { "value": "8px",    "role": "badges, small chips" },
    "md":   { "value": "12px",   "role": "inputs, small cards" },
    "lg":   { "value": "16px",   "role": "cards. The default container." },
    "full": { "value": "9999px", "role": "buttons, pills, avatars" }
  },

  "shadow": {
    "card":    { "value": "0 1px 3px rgba(0,0,0,.06), 0 1px 2px rgba(0,0,0,.04)",   "role": "resting card" },
    "card-md": { "value": "0 4px 6px rgba(0,0,0,.05), 0 2px 4px rgba(0,0,0,.03)",   "role": "hover lift" },
    "card-lg": { "value": "0 10px 25px rgba(0,0,0,.06), 0 4px 10px rgba(0,0,0,.04)","role": "modal, popover" }
  },

  "motion": {
    "ease":            { "value": "cubic-bezier(0.16, 1, 0.3, 1)", "role": "the one easing curve" },
    "duration-micro":  { "value": "200ms", "role": "hover, color change" },
    "duration-state":  { "value": "400ms", "role": "state transition" },
    "duration-reveal": { "value": "700ms", "role": "scroll reveal" },
    "lift":            { "value": "-2px",  "role": "hover translateY" }
  },

  "contrast": [
    { "label": "body text on card",        "mode": "light", "fg": "content.fg",     "bg": "surface.card" },
    { "label": "body text on page",        "mode": "light", "fg": "content.fg",     "bg": "surface.bg" },
    { "label": "muted text on card",       "mode": "light", "fg": "content.muted",  "bg": "surface.card" },
    { "label": "faint text on card",       "mode": "light", "fg": "content.faint",  "bg": "surface.card" },
    { "label": "link on card",             "mode": "light", "fg": "brand.accent-ink","bg": "surface.card" },
    { "label": "button label on accent",   "mode": "light", "fg": "brand.on-accent","bg": "brand.accent" },
    { "label": "prose at 70% on card",     "mode": "light", "fg": "content.fg",     "bg": "surface.card", "alpha": 0.7 },
    { "label": "muted on page",            "mode": "light", "fg": "content.muted",  "bg": "surface.bg" },
    { "label": "faint on page",            "mode": "light", "fg": "content.faint",  "bg": "surface.bg" },
    { "label": "body on gradient end",     "mode": "light", "fg": "content.fg",     "bg": "surface.bg-end" },
    { "label": "muted on gradient end",    "mode": "light", "fg": "content.muted",  "bg": "surface.bg-end" },
    { "label": "faint on gradient end",    "mode": "light", "fg": "content.faint",  "bg": "surface.bg-end" },
    { "label": "link on gradient end",     "mode": "light", "fg": "brand.accent-ink","bg": "surface.bg-end" },
    { "label": "hairline on card",         "mode": "light", "fg": "surface.line",   "bg": "surface.card", "decorative": true },

    { "label": "body text on card",        "mode": "dark",  "fg": "content.fg",     "bg": "surface.card" },
    { "label": "body text on page",        "mode": "dark",  "fg": "content.fg",     "bg": "surface.bg" },
    { "label": "muted text on card",       "mode": "dark",  "fg": "content.muted",  "bg": "surface.card" },
    { "label": "faint text on card",       "mode": "dark",  "fg": "content.faint",  "bg": "surface.card" },
    { "label": "link on card",             "mode": "dark",  "fg": "brand.accent",   "bg": "surface.card" },
    { "label": "button label on accent",   "mode": "dark",  "fg": "brand.on-accent","bg": "brand.accent" },
    { "label": "prose at 70% on card",     "mode": "dark",  "fg": "content.fg",     "bg": "surface.card", "alpha": 0.7 },

    { "label": "sights dot on card",       "mode": "light", "fg": "section.sights",     "bg": "surface.card", "decorative": true },
    { "label": "sounds dot on card",       "mode": "light", "fg": "section.sounds",     "bg": "surface.card", "decorative": true },
    { "label": "curiosity dot on card",    "mode": "light", "fg": "section.curiosity",  "bg": "surface.card", "decorative": true },
    { "label": "creativity dot on card",   "mode": "light", "fg": "section.creativity", "bg": "surface.card", "decorative": true },
    { "label": "alert text on card",       "mode": "light", "fg": "section.alert-ink",  "bg": "surface.card" },
    { "label": "alert text on card",       "mode": "dark",  "fg": "section.alert-ink",  "bg": "surface.card" },
    { "label": "muted on card",            "mode": "dark",  "fg": "content.muted",      "bg": "surface.card" }
  ]
}
